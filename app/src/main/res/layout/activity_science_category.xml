<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".science_category">


    <!-- BACKGROUND -->
    <ImageView
        android:id="@+id/imageView10"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/science_bg2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- BACK BUTTON -->
    <ImageView
        android:id="@+id/imageView11"
        android:layout_width="120dp"
        android:layout_height="80dp"
        app:srcCompat="@drawable/back_btn"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"/>


    <!-- ANIMALS BUTTON -->
    <Button
        android:id="@+id/buttonAnimals"
        android:layout_width="220dp"
        android:layout_height="78dp"
        android:text="Animals"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.30"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- PLANTS BUTTON -->
    <Button
        android:id="@+id/buttonPlants"
        android:layout_width="220dp"
        android:layout_height="78dp"
        android:text="Plants"
        app:layout_constraintTop_toBottomOf="@id/buttonAnimals"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>


    <!-- EARTH AND NATURE BUTTON -->
    <Button
        android:id="@+id/buttonEarth"
        android:layout_width="220dp"
        android:layout_height="78dp"
        android:text="Earth And Nature"
        app:layout_constraintTop_toBottomOf="@id/buttonPlants"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>