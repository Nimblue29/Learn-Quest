<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_home"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- ── Logo Section ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/logoSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮"
            android:textSize="72sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvMainLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LearnQuest"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="@color/purple_primary"
            android:layout_marginTop="8dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvMainLogoSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEARN · PLAY · GROW"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:textColor="@color/text_muted"
            android:layout_marginTop="4dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvMainTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Every game makes you smarter! ✨"
            android:textSize="14sp"
            android:textColor="@color/orange_primary"
            android:layout_marginTop="10dp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- ── Menu Card ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/menuCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginBottom="16dp">

        <!-- Player chip -->
        <TextView
            android:id="@+id/tvPlayerChip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill_purple"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:text="👤 Player  ⭐ 0  🔥 0"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="18dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- PLAY Button -->
        <TextView
            android:id="@+id/btnMainPlay"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_btn_primary_green"
            android:text="▶  PLAY NOW"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Dashboard Button -->
        <TextView
            android:id="@+id/btnMainDashboard"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_btn_primary_blue"
            android:text="📊  My Progress"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Bottom row: Sound + About -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnSoundToggle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_btn_outline_pink"
                android:text="🔊  Sound On"
                android:textColor="@color/pink_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnAbout"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_pill_purple"
                android:text="ℹ️  About"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Version label -->
    <TextView
        android:id="@+id/tvVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0 · Paul Ace Ocampo · BSIT-2C"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:gravity="center"/>

</LinearLayout>
