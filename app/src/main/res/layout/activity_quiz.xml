<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard">

    <!-- ── Main Game Layout ────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnQuizBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_card_white"
                    android:text="←"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📝  Quick Quiz"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>

                <TextView
                    android:id="@+id/tvQuizScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:text="⭐ 0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/purple_primary"/>

            </LinearLayout>

            <!-- Progress Dots -->
            <LinearLayout
                android:id="@+id/quizProgressDots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <!-- Timer Bar -->
            <LinearLayout
                android:id="@+id/quizTimerTrack"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/bg_timer_track"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/quizTimerFill"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_timer_fill_blue"
                    android:transformPivotX="0dp"/>

            </LinearLayout>

            <!-- Question Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <!-- Q number + Timer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tvQNum"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Q 1 / 7"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"/>

                    <TextView
                        android:id="@+id/tvQuizCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_pill_purple"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="🔢 Question"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:id="@+id/tvQuizTimer"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_white"
                        android:text="15"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:gravity="center"/>

                </LinearLayout>

                <!-- Question text -->
                <TextView
                    android:id="@+id/tvQuizQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What is 5 + 7?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:gravity="center"
                    android:minHeight="80dp"/>

                <!-- Feedback row -->
                <TextView
                    android:id="@+id/tvQuizFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Correct!"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_primary"
                    android:gravity="center"
                    android:layout_marginTop="8dp"
                    android:visibility="invisible"/>

            </LinearLayout>

            <!-- Answer Options (2x2 grid) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/btnOpt1"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_answer_btn"
                        android:text="Option A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btnOpt2"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_answer_btn"
                        android:text="Option B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnOpt3"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_answer_btn"
                        android:text="Option C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/btnOpt4"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_answer_btn"
                        android:text="Option D"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── Result Card (shown at end) ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/quizResultCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#CC9B59B6"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvQuizResultEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="60sp"/>

            <TextView
                android:id="@+id/tvQuizResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz Complete!"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/purple_primary"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvQuizResultSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Great effort!"
                android:textSize="14sp"
                android:textColor="@color/text_muted"
                android:layout_marginTop="4dp"
                android:gravity="center"/>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_card_orange"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvQuizStatCorrect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7/7"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Score"
                        android:textSize="10sp"
                        android:textColor="@color/white"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_pill_green"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp">

                    <TextView
                        android:id="@+id/tvQuizStatStars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+21 ⭐"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Earned"
                        android:textSize="10sp"
                        android:textColor="@color/white"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_pill_blue"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvQuizStatTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5s avg"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Per Q"
                        android:textSize="10sp"
                        android:textColor="@color/white"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Play Again -->
            <TextView
                android:id="@+id/btnQuizPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary_green"
                android:text="🎮  Play Again!"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnQuizBack"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_outline_pink"
                android:text="← Back to Menu"
                android:textColor="@color/pink_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
