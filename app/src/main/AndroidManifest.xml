<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.learnquest">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LearnQuest">

        <!-- LAUNCHER: Main Menu splash screen -->
        <activity
            android:name="com.example.learnquest.activities.MainMenuActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.learnquest.activities.HomeActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name="com.example.learnquest.activities.SpellingActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name="com.example.learnquest.activities.MathBattleActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name="com.example.learnquest.activities.PuzzleActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name="com.example.learnquest.activities.QuizActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name="com.example.learnquest.activities.DashboardActivity"
            android:screenOrientation="portrait"
            android:exported="false" />

        <activity
            android:name="com.example.learnquest.End_Game"
            android:exported="false" />
        <activity
            android:name="com.example.learnquest.science_category"
            android:exported="false" />
        <activity
            android:name="com.example.learnquest.Addition_Game"
            android:exported="false" />
        <activity
            android:name="com.example.learnquest.Math_Level"
            android:exported="false" />
        <activity
            android:name="com.example.learnquest.GameOption"
            android:exported="false" />
        <activity
            android:name="com.example.learnquest.science_quiz"
            android:exported="false" />
        <activity
            android:name="com.example.learnquest.MainActivity"
            android:exported="false" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

    </application>

</manifest>
